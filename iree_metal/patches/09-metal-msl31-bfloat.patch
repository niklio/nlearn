diff --git a/runtime/src/iree/hal/drivers/metal/executable.m b/runtime/src/iree/hal/drivers/metal/executable.m
index 4de38c9..bc8c3a3 100644
--- a/runtime/src/iree/hal/drivers/metal/executable.m
