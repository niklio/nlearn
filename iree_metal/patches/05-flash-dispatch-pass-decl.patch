+def ConvertFlashAttentionDispatch :
+    Pass<"iree-stablehlo-convert-flash-attention-dispatch", "mlir::ModuleOp"> {
+  let summary = "Lowers @flash_attention_* custom calls to flow.dispatch of external Metal kernels";
+  let description = [{
+    Replaces `stablehlo.custom_call` ops whose call_target_name is one of
+    flash_attention_fwd / flash_attention_bwd_dq / flash_attention_bwd_dkdv with
+    a call to a generated wrapper function that flow.dispatches the
+    corresponding hand-authored external Metal kernel (flash_attention.metal).
+    The wrapper (hal.executable.source + flow.dispatch) is parsed from a string
+    template specialized to the call's (n_heads, seq_len, d_head) shape, so no
+    HAL C++ dependency is needed in this library.
+  }];
+}
