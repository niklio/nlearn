diff --git a/integrations/pjrt/cmake/protobuf_cc_library.cmake b/integrations/pjrt/cmake/protobuf_cc_library.cmake
index afdd54e..971660d 100644
--- a/integrations/pjrt/cmake/protobuf_cc_library.cmake
+++ b/integrations/pjrt/cmake/protobuf_cc_library.cmake
@@ -16,11 +16,16 @@ set(protobuf_FORCE_FETCH_DEPENDENCIES ON)
 # pin the version of protobuf
 set(protobuf_VERSION 29.1)
 
+# Patch the abseil bundled with protobuf so it builds with Apple clang 17.
+# The patch logic lives in a standalone script: embedding the sed expression
+# directly in PATCH_COMMAND breaks because CMake's argument parsing mangles the
+# nested quotes in `"x86_64" "arm64"`. See the script for the why.
 FetchContent_Declare(
   protobuf
   GIT_REPOSITORY https://github.com/protocolbuffers/protobuf
   GIT_TAG v${protobuf_VERSION}
   GIT_SHALLOW ON
+  PATCH_COMMAND sh "${CMAKE_CURRENT_LIST_DIR}/patch_protobuf_absl.sh"
 )
 
 FetchContent_MakeAvailable(protobuf)
